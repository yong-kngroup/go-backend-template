# Local-only secrets and configuration. Copy this file to .env and set your values.
DATABASE_DSN=host=localhost user=postgres password=postgres dbname=go_backend port=5432 sslmode=disable TimeZone=Asia/Shanghai
REDIS_ADDR=localhost:6379
MQ_KAFKA_BROKERS=localhost:9092
TRACING_ENDPOINT=localhost:4318

AUTH_JWT_SECRET=replace-with-a-local-development-secret

# Required by cmd/server only when MCP_ENABLED=true. The MCP client receives
# its own CMS_MCP_CLIENT_ID and CMS_MCP_CLIENT_SECRET directly from Codex.
MCP_ENABLED=false
MCP_SERVICE_ACCOUNT_NAME=MCP Operator
MCP_SERVICE_ACCOUNT_EMAIL=mcp-operator@example.com
MCP_CLIENT_ID=
MCP_CLIENT_SECRET=
MCP_SERVICE_ACCOUNT_ENABLED=true
MCP_SECRET_ROTATION_GRACE_MINUTES=60
MCP_TOKEN_AUDIENCE=cms-api
MCP_ACCESS_TOKEN_TTL_MINUTES=10

EMAIL_MODE=log
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=developer@example.com
EMAIL_SMTP_PASSWORD=replace-with-an-app-password
EMAIL_FROM_ADDRESS=developer@example.com
EMAIL_SITE_BASE_URL=http://localhost:5173

STORAGE_S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
STORAGE_S3_REGION=auto
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_BUCKET=
STORAGE_S3_PUBLIC_BASE_URL=
STORAGE_S3_PREFIX=cms
STORAGE_S3_USE_PATH_STYLE=true
STORAGE_S3_PRESIGN_TTL_MINUTES=15

# Integration tests use dedicated resources and never read application Redis DB settings.
TEST_DATABASE_DSN=host=localhost user=postgres password=postgres dbname=go_backend port=5432 sslmode=disable TimeZone=Asia/Shanghai
TEST_REDIS_ADDR=localhost:6379
TEST_REDIS_PASSWORD=
TEST_REDIS_DB=15
TEST_KAFKA_BROKERS=localhost:9092
TEST_S3_ENDPOINT=http://localhost:9000
TEST_S3_REGION=us-east-1
TEST_S3_ACCESS_KEY_ID=minioadmin
TEST_S3_SECRET_ACCESS_KEY=minioadmin
TEST_S3_BUCKET=go-backend-template-test

CRON_MEDIA_UPLOAD_CLEANUP_INTERVAL_SECONDS=300
CRON_MEDIA_UPLOAD_CLEANUP_BATCH_SIZE=100
